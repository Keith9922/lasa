# MiniMax OpenAI-compatible API
# 不填则 AI 接口走兜底（可用但功能降级）。
#
# 域名说明：
# - 国内 token plan（key 形如 sk-cp-...）→ https://api.minimaxi.com/v1
# - 海外版本                              → https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7

# ===== Auth.js v5 =====
# 32+ 字符随机串。生成命令：openssl rand -base64 32
# 没设的话 dev 模式 NextAuth 会自动生成（每次重启都换，session 会失效）
AUTH_SECRET=

# 部署后的真实站点 URL（含协议），用于 OAuth 回调
# 本地 dev 自动用 http://localhost:3000，可不填
AUTH_URL=

# GitHub OAuth —— 在 https://github.com/settings/applications/new 建一个 App
#   Authorization callback URL: ${AUTH_URL}/api/auth/callback/github
# 不填的话登录页只显示「邮箱 + 昵称」demo 登录
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Demo provider 开关。生产环境强烈建议设 off，否则任何邮箱都能登录
# 默认 on
AUTH_DEMO=on
